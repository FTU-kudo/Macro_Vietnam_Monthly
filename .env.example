# .env.example
# Copy file này thành .env và điền thông tin thật
# File .env KHÔNG được commit lên Git (đã có trong .gitignore)

# ── Google Gemini API ──────────────────────────────────────
# Lấy tại: https://aistudio.google.com/api-keys
GEMINI_API_KEY=[Your Gemini Key]

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Gmail address để gửi email
GMAIL_USER=your-report-email@gmail.com

# App Password Gmail (16 ký tự, không phải mật khẩu thường)
# Tạo tại: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Danh sách nhận email (cách nhau dấu phẩy)
RECIPIENT_EMAILS=tom@company.com,colleague@company.com
